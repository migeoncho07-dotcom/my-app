rules_version = '2';

// airang Firestore security rules
// 1) signed-in users only  2) own group data only  3) invite codes server-only
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // users/{uid} : profile
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;

      // 알림 — 본인만 읽기. 쓰기는 서버(Admin SDK)만 (직접 쓰기 차단)
      match /notifications/{nid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // groups/{groupId}
    match /groups/{groupId} {
      allow read: if isGroupMember(groupId);
      allow create: if isSignedIn() && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if isGroupMember(groupId);

      // members/{uid}
      match /members/{memberId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isSignedIn() && (request.auth.uid == memberId || isGroupMember(groupId));
      }

      // places/{placeId}
      match /places/{placeId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && request.resource.data.added_by == request.auth.uid;
        // 수정: 그룹 멤버 누구나 / 삭제: 작성자 본인만
        allow update: if isGroupMember(groupId);
        allow delete: if isGroupMember(groupId) && resource.data.added_by == request.auth.uid;

        // ratings/{uid} : 평점은 본인 것만 작성·수정·삭제 (문서 ID = 작성자 uid)
        // (실제 쓰기는 서버 Admin SDK 경유. 직접 접근 시에도 안전하도록 제한)
        match /ratings/{ratingUid} {
          allow read: if isGroupMember(groupId);
          allow create, update, delete: if isGroupMember(groupId) && request.auth.uid == ratingUid;
        }
      }
    }

    // invite_codes/{code} : client access fully blocked (server Admin SDK only)
    match /invite_codes/{code} {
      allow read, write: if false;
    }
  }
}
